{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "ngtip_apikey": {
      "type": "string",
      "description": "ThreatBook NGTIP V5 API key."
    },
    "apikey": {
      "type": "string",
      "description": "Alias for ngtip_apikey."
    },
    "apiKey": {
      "type": "string",
      "description": "Alias for ngtip_apikey."
    },
    "salt": {
      "type": "string",
      "description": "Salt for TOKEN authentication (HMAC_SHA1). Required when auth_mode is token."
    },
    "auth_mode": {
      "type": "string",
      "enum": ["apikey", "token"],
      "default": "apikey",
      "description": "Authentication mode: 'apikey' uses simple API key, 'token' uses HMAC_SHA1 signed token."
    }
  }
}
