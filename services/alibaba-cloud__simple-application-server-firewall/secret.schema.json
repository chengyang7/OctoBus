{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "accessKeyId": {
      "type": "string",
      "description": "Alibaba Cloud AccessKey ID."
    },
    "access_key_id": {
      "type": "string",
      "description": "Alias for accessKeyId."
    },
    "accessKeySecret": {
      "type": "string",
      "description": "Alibaba Cloud AccessKey Secret."
    },
    "access_key_secret": {
      "type": "string",
      "description": "Alias for accessKeySecret."
    },
    "securityToken": {
      "type": "string",
      "description": "Optional STS security token."
    },
    "security_token": {
      "type": "string",
      "description": "Alias for securityToken."
    }
  }
}
