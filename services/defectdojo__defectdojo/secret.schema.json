{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "defectdojo_api_key": {
      "type": "string",
      "description": "DefectDojo API v2 token value, without the Token prefix."
    },
    "apiKey": {
      "type": "string",
      "description": "Alias for defectdojo_api_key."
    },
    "token": {
      "type": "string",
      "description": "Alias for defectdojo_api_key."
    }
  }
}
